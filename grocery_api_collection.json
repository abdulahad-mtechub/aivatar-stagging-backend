				{
					"name": "Get Daily Ingredients",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/ingredients?date=2026-03-12",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"ingredients"
							],
							"query": [
								{
									"key": "date",
									"value": "2026-03-12"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Add to Grocery List",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"mealIds\": [1, 2, 3]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/ingredients/add-to-grocery",
