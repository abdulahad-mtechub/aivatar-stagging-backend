{
	"info": {
		"_postman_id": "b2c3d4e5-f6a7-8901-bcde-f1234567890a",
		"name": "Aivatar Report & Measurement APIs",
		"description": "Collection for testing Daily/Weekly Reports and Physical Measurement tracking.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Measurements",
			"item": [
				{
					"name": "Log Measurement",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"weight\": 80.5,\n    \"waist\": 90.0,\n    \"chest\": 100.0,\n    \"hips\": 105.0,\n    \"arm\": 35.0,\n    \"recorded_date\": \"2026-03-12\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/measurements",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"measurements"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Last Measurement",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/measurements/latest",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"measurements",
								"latest"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get History",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/measurements/history?limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"measurements",
								"history"
							],
							"query": [
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Reports",
			"item": [
				{
					"name": "Daily Report",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/reports/daily?date=2026-03-12",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"reports",
								"daily"
							],
							"query": [
								{
									"key": "date",
									"value": "2026-03-12"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Weekly Report",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/reports/weekly",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"reports",
								"weekly"
							]
						}
					},
					"response": []
				},
				{
					"name": "Goal Prediction",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/reports/prediction",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"reports",
								"prediction"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000"
		},
		{
			"key": "token",
			"value": "paste_your_token_here"
		}
	]
}
