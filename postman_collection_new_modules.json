{
  "info": {
    "name": "Aivatar New Modules (Contact, Workout, Coins & Badges)",
    "description": "API collection for Contact Us, Workout, Rewards, Redeem and Badge modules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000", "type": "string" }
  ],
  "item": [
    {
      "name": "Contact Us",
      "item": [
        {
          "name": "Submit Query",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alex Smith\",\n  \"email\": \"alex@example.com\",\n  \"query\": \"I have a question about the Upper Body workout plan.\"\n}" },
            "url": { "raw": "{{base_url}}/api/contacts", "host": ["{{base_url}}"], "path": ["api","contacts"] }
          }
        },
        {
          "name": "Get All Queries (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/contacts?page=1&limit=10", "host": ["{{base_url}}"], "path": ["api","contacts"], "query": [{ "key": "page", "value": "1" },{ "key": "limit", "value": "10" }] }
          }
        }
      ]
    },
    {
      "name": "Workout & Exercise",
      "item": [
        {
          "name": "Save AI Exercise",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"AI Squats\",\n  \"description\": \"Squats generated by AI\",\n  \"media_url\": \"https://example.com/squat.mp4\",\n  \"instructions\": { \"steps\": [\"Stand straight\", \"Lower body\"] },\n  \"category\": \"Strength\",\n  \"target_muscle_group\": \"Legs\"\n}" },
            "url": { "raw": "{{base_url}}/api/workouts/exercises", "host": ["{{base_url}}"], "path": ["api","workouts","exercises"] }
          }
        },
        {
          "name": "Save AI Workout Plan",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"AI Full Body\",\n  \"duration_minutes\": 30,\n  \"difficulty\": \"Beginner\",\n  \"exercises\": [\n    { \"id\": 1, \"sets\": 3, \"reps\": 12 }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/api/workouts", "host": ["{{base_url}}"], "path": ["api","workouts"] }
          }
        },
        {
          "name": "List All Workouts",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/workouts", "host": ["{{base_url}}"], "path": ["api","workouts"] }
          }
        },
        {
          "name": "Get Workout Details",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/workouts/1", "host": ["{{base_url}}"], "path": ["api","workouts","1"] }
          }
        },
        {
          "name": "Get Exercise Guide",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/workouts/exercises/1", "host": ["{{base_url}}"], "path": ["api","workouts","exercises","1"] }
          }
        },
        {
          "name": "Start Workout Session",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"workout_id\": 1\n}" },
            "url": { "raw": "{{base_url}}/api/workouts/sessions/start", "host": ["{{base_url}}"], "path": ["api","workouts","sessions","start"] }
          }
        },
        {
          "name": "Log Workout Set",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"session_id\": 1,\n  \"exercise_id\": 1,\n  \"set_number\": 1,\n  \"reps\": 10,\n  \"weight\": 80.5,\n  \"reps_target\": 12,\n  \"weight_target\": 80,\n  \"rest_time\": 60\n}" },
            "url": { "raw": "{{base_url}}/api/workouts/sessions/log-set", "host": ["{{base_url}}"], "path": ["api","workouts","sessions","log-set"] }
          }
        },
        {
          "name": "Complete Workout Session",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"session_id\": 1\n}" },
            "url": { "raw": "{{base_url}}/api/workouts/sessions/complete", "host": ["{{base_url}}"], "path": ["api","workouts","sessions","complete"] }
          }
        }
      ]
    },
    {
      "name": "Rewards (Coins)",
      "item": [
        {
          "name": "Earn Points (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rule_id\": 1\n}" },
            "url": { "raw": "{{base_url}}/api/rewards/earn", "host": ["{{base_url}}"], "path": ["api","rewards","earn"] },
            "description": "User earns coins. rule_id: 1 = Daily Login (10pts), 2 = Complete Workout (50pts)"
          }
        },
        {
          "name": "Get My Balance (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/rewards/balance", "host": ["{{base_url}}"], "path": ["api","rewards","balance"] }
          }
        },
        {
          "name": "Get My Earning History (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/rewards/history?page=1&limit=10", "host": ["{{base_url}}"], "path": ["api","rewards","history"] }
          }
        },
        {
          "name": "Get All Rules (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/rewards/rules", "host": ["{{base_url}}"], "path": ["api","rewards","rules"] }
          }
        },
        {
          "name": "Create Reward Rule (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Weekly Challenge\",\n  \"description\": \"Complete 5 workouts in a week\",\n  \"module_type\": \"workout\",\n  \"trigger_event\": \"weekly_challenge\",\n  \"reward_type\": \"challenge\",\n  \"points_amount\": 100,\n  \"frequency_limit\": \"weekly\",\n  \"events_per_day\": 1,\n  \"is_active\": true\n}" },
            "url": { "raw": "{{base_url}}/api/rewards/rules", "host": ["{{base_url}}"], "path": ["api","rewards","rules"] }
          }
        },
        {
          "name": "Update Reward Rule (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"points_amount\": 20,\n  \"is_active\": true\n}" },
            "url": { "raw": "{{base_url}}/api/rewards/rules/1", "host": ["{{base_url}}"], "path": ["api","rewards","rules","1"] }
          }
        },
        {
          "name": "Delete Reward Rule (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "DELETE", "header": [],
            "url": { "raw": "{{base_url}}/api/rewards/rules/1", "host": ["{{base_url}}"], "path": ["api","rewards","rules","1"] }
          }
        }
      ]
    },
    {
      "name": "Redeem Coins",
      "item": [
        {
          "name": "Redeem Coins (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rule_id\": 1\n}" },
            "url": { "raw": "{{base_url}}/api/redeem", "host": ["{{base_url}}"], "path": ["api","redeem"] },
            "description": "Redeems coins. Returns unique redeem_code like RC-A1B2C3"
          }
        },
        {
          "name": "Get My Redeem History (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/redeem/history?page=1&limit=10", "host": ["{{base_url}}"], "path": ["api","redeem","history"] }
          }
        }
      ]
    },
    {
      "name": "Badges",
      "item": [
        {
          "name": "Get All Badges (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/badges", "host": ["{{base_url}}"], "path": ["api","badges"] }
          }
        },
        {
          "name": "Get My Active Badge (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/badges/my-badge", "host": ["{{base_url}}"], "path": ["api","badges","my-badge"] },
            "description": "Returns current balance + active badge based on points"
          }
        },
        {
          "name": "Create Badge (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Diamond\",\n  \"max_points\": 10000,\n  \"color\": \"diamond\",\n  \"color_value\": \"#B9F2FF\",\n  \"badge_image\": \"https://example.com/diamond.png\"\n}" },
            "url": { "raw": "{{base_url}}/api/badges", "host": ["{{base_url}}"], "path": ["api","badges"] }
          }
        },
        {
          "name": "Update Badge (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"max_points\": 200\n}" },
            "url": { "raw": "{{base_url}}/api/badges/1", "host": ["{{base_url}}"], "path": ["api","badges","1"] }
          }
        },
        {
          "name": "Delete Badge (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "DELETE", "header": [],
            "url": { "raw": "{{base_url}}/api/badges/1", "host": ["{{base_url}}"], "path": ["api","badges","1"] }
          }
        }
      ]
    }
  ]
}
